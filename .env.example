# Supabase - Visitor Counter
# Create a free Supabase project, then create a "visitors" table:
#   id: bigint (primary key, identity)
#   count: bigint (default 0)
#   created_at: timestamptz (default now())
#
# Insert initial row: INSERT INTO visitors (count) VALUES (0);
#
# Create this SQL function for the increment:
#   CREATE OR REPLACE FUNCTION increment_visitor()
#   RETURNS bigint
#   LANGUAGE sql
#   AS $$
#     UPDATE visitors SET count = count + 1 WHERE id = 1 RETURNING count;
#   $$;
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
