# Admin Authentication — set these in Vercel dashboard:
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# SESSION_SECRET=

# Supabase — Visitor Counter + Data Store:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# GitHub — Auto-sync data changes to repo so Vercel redeploys:
# GITHUB_TOKEN=
# GIT_REPO_OWNER=saad-affan12
# GIT_REPO_NAME=Saad-Affan-Portfolio
# GIT_BRANCH=main
